  </svg>
)}

{name === 'sun' && (
  <svg {...common}>
    <circle cx="12" cy="12" r="4" />
    <path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4" />
  </svg>
)}

{name === 'cobra' && (
  <svg {...common}>
    <path d="M12 20c-4 0-6-2-6-5s2-4 4-4 3 1 3 2.5-1 2-2 2-1.5-.5-1.5-1" />
    <path d="M12 20c4 0 6-2 6-5s-2-4-4-4-3 1-3 2.5 1 2 2 2 1.5-.5 1.5-1" />
    <path d="M12 11V4M10 6c0-1 1-2 2-2s2 1 2 2" />
    <circle cx="10.5" cy="7.5" r="0.4" fill="currentColor" />
    <circle cx="13.5" cy="7.5" r="0.4" fill="currentColor" />
  </svg>
)}
