---
// Single-file SVG icon set. Replaces every emoji-as-icon in the old site.
// Icons are drawn on a 24x24 grid, stroke-based, currentColor-tinted.
// Source: hand-authored, inspired by Lucide (ISC, free).

type IconName =
  | 'target'
  | 'shopping-cart'
  | 'phone'
  | 'link'
  | 'bolt'
  | 'shopify'
  | 'meta'
  | 'amazon'
  | 'cpu'
  | 'database'
  | 'shield'
  | 'chart'
  | 'arrow-right'
  | 'arrow-up-right'
  | 'check'
  | 'spark'
  | 'cobra'
  | 'code'
  | 'layers'
  | 'send'
  | 'sun';

interface Props {
  name: IconName;
  size?: number | string;
  class?: string;
  'stroke-width'?: number;
  title?: string;
}

const {
  name,
  size = 20,
  class: className = '',
  'stroke-width': strokeWidth = 1.75,
  title,
} = Astro.props;

const common = {
  width: size,
  height: size,
  viewBox: '0 0 24 24',
  fill: 'none',
  stroke: 'currentColor',
  'stroke-width': strokeWidth,
  'stroke-linecap': 'round' as const,
  'stroke-linejoin': 'round' as const,
  class: className,
  role: (title ? 'img' : undefined) as 'img' | undefined,
  'aria-label': title,
  'aria-hidden': (title ? undefined : 'true') as 'true' | undefined,
};
---

{name === 'target' && (
  <svg {...common}>
    <circle cx="12" cy="12" r="9" />
    <circle cx="12" cy="12" r="5" />
    <circle cx="12" cy="12" r="1.5" />
  </svg>
)}

{name === 'shopping-cart' && (
  <svg {...common}>
    <path d="M3 4h2l2.6 11.2a2 2 0 0 0 2 1.6h7.2a2 2 0 0 0 2-1.5L21 8H6" />
    <circle cx="10" cy="20" r="1.2" />
    <circle cx="17" cy="20" r="1.2" />
  </svg>
)}

{name === 'phone' && (
  <svg {...common}>
    <path d="M5 4h3l2 5-2.3 1.2a12 12 0 0 0 6.1 6.1L15 14l5 2v3a2 2 0 0 1-2 2A15 15 0 0 1 3 6a2 2 0 0 1 2-2z" />
  </svg>
)}

{name === 'link' && (
  <svg {...common}>
    <path d="M10 14a5 5 0 0 0 7 0l3-3a5 5 0 0 0-7-7l-1.5 1.5" />
    <path d="M14 10a5 5 0 0 0-7 0l-3 3a5 5 0 0 0 7 7l1.5-1.5" />
  </svg>
)}

{name === 'bolt' && (
  <svg {...common}>
    <path d="M13 2 4 14h7l-1 8 9-12h-7l1-8z" />
  </svg>
)}

{name === 'shopify' && (
  <svg {...common}>
    <path d="M15.3 4.2c-.6-.1-1 .4-1.2.9-.8-.2-1.7.1-2.4 1-.7.8-1.1 2-1.3 2.9L7 9.3v10.5l10.5 1.2V8.5l-2.2-.3" />
    <path d="M12.5 7.2c.1-.5.4-1.2.9-1.5" />
  </svg>
)}

{name === 'meta' && (
  <svg {...common}>
    <path d="M3 12c3-7 7-7 9 0 2 7 6 7 9 0" />
    <path d="M3 12c3 7 7 7 9 0 2-7 6-7 9 0" />
  </svg>
)}

{name === 'amazon' && (
  <svg {...common}>
    <path d="M4 17c4 3 12 3 16 0" />
    <path d="M6 19.5c1 .8 2 1 3 1" />
    <path d="M8 10.5c0-2 1.5-3.5 4-3.5s4 1 4 3v5c0 1 .3 1.5 1 2" />
    <path d="M8.5 13c0 1.5 1 2.5 2.5 2.5S14 14 14 12v-1.5c-4 0-5.5 1-5.5 2.5z" />
  </svg>
)}

{name === 'cpu' && (
  <svg {...common}>
    <rect x="5" y="5" width="14" height="14" rx="2" />
    <rect x="9" y="9" width="6" height="6" rx="1" />
    <path d="M9 2v3M15 2v3M9 19v3M15 19v3M2 9h3M2 15h3M19 9h3M19 15h3" />
  </svg>
)}

{name === 'database' && (
  <svg {...common}>
    <ellipse cx="12" cy="5" rx="8" ry="3" />
    <path d="M4 5v6c0 1.7 3.6 3 8 3s8-1.3 8-3V5" />
    <path d="M4 11v6c0 1.7 3.6 3 8 3s8-1.3 8-3v-6" />
  </svg>
)}

{name === 'shield' && (
  <svg {...common}>
    <path d="M12 3 4 6v6c0 4.5 3.5 8.5 8 9 4.5-.5 8-4.5 8-9V6l-8-3z" />
    <path d="m9 12 2 2 4-4" />
  </svg>
)}

{name === 'chart' && (
  <svg {...common}>
    <path d="M4 20V10M10 20V4M16 20v-7M22 20H2" />
  </svg>
)}

{name === 'arrow-right' && (
  <svg {...common}>
