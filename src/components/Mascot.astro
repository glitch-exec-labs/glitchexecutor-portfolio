---
// Responsive cobra mascot, served through Astro <Image> for AVIF/WebP.
// Cover alt defaults to a description; decorative usages should pass alt="".
import { Image } from 'astro:assets';
import mascot from '~/assets/mascot-512.png';

interface Props {
  size?: number;
  alt?: string;
  class?: string;
  priority?: boolean;
}
const { size = 96, alt = 'Glitch cobra mascot', class: className = '', priority = false } = Astro.props;
---

<Image
  src={mascot}
  width={size * 2}
  height={size * 2}
  alt={alt}
  class:list={['rounded-xl', className]}
  loading={priority ? 'eager' : 'lazy'}
  decoding={priority ? 'sync' : 'async'}
  quality={82}
  format="avif"
/>
