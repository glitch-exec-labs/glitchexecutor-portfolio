---
import Icon from '~/components/Icon.astro';
import { subBrands } from '~/lib/site';
---

<section id="portfolio" class="py-24 md:py-32 border-y border-border/60 bg-surface/30">
  <div class="container-app">
    <div class="max-w-2xl reveal">
      <p class="eyebrow"><Icon name="layers" size={14} /> Portfolio</p>
      <h2 class="mt-4">Three product lines. One operating system.</h2>
      <p class="mt-5 text-fluid-lg text-muted">
        Each sub-brand runs on the same shared stack — agent ensemble, shared
        data layer, shared execution primitives — but ships with a vertical-specific
        surface area. Pick the one closest to your problem.
      </p>
    </div>

    <ul class="mt-14 grid gap-6 md:grid-cols-3" role="list">
      {subBrands.map((b) => (
        <li class="card p-6 md:p-8 reveal group relative flex flex-col h-full
                   hover:border-brand/40 transition-colors">
          <div aria-hidden="true"
               class="pointer-events-none absolute inset-0 -z-10 opacity-0 group-hover:opacity-100
                      transition-opacity duration-500 rounded-[inherit]
                      bg-[radial-gradient(circle_at_top,rgb(var(--color-brand)/0.08),transparent_70%)]">
          </div>

          <div class="flex items-center gap-3">
            <span class="inline-flex size-11 items-center justify-center rounded-md bg-brand/10 text-brand border border-brand/20">
              <Icon name={b.icon} size={22} />
            </span>
            <div>
              <h3 class="text-fluid-xl leading-none">{b.name}</h3>
              <p class="mt-1 font-mono text-fluid-xs text-subtle">{b.slug}.glitchexecutor.com</p>
            </div>
          </div>

          <p class="mt-5 text-fluid-base text-fg/90">{b.tagline}</p>

          <ul class="mt-5 space-y-2 text-fluid-sm" role="list">
            {b.proof.map((p) => (
              <li class="flex items-start gap-2">
                <span class="mt-[3px] text-brand"><Icon name="check" size={14} /></span>
                <span class="text-muted">{p}</span>
              </li>
            ))}
          </ul>

          <div class="mt-auto pt-6">
            <a
              href={b.href}
              rel="noopener"
              class="inline-flex items-center gap-1.5 text-brand text-fluid-sm font-medium
                     underline decoration-brand/30 hover:decoration-brand"
              data-cta={`portfolio-${b.slug}`}
            >
              Visit {b.name}
              <Icon name="arrow-up-right" size={14} />
            </a>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>
