---
import Base from '~/layouts/Base.astro';
import { site } from '~/lib/site';
const updated = '2026-04-19';
---

<Base title="Terms" description="Terms of use for Glitch Executor." pageType="WebPage">
  <section class="container-app py-20 max-w-prose-tight">
    <p class="eyebrow">Legal</p>
    <h1 class="mt-4">Terms of Use</h1>
    <p class="mt-4 text-subtle text-fluid-sm">Last updated: {updated}</p>

    <div class="prose mt-10 text-muted [&_h2]:text-fg [&_h2]:mt-10 [&_h2]:mb-3 [&_h2]:text-fluid-xl [&_p]:my-3 [&_strong]:text-fg [&_ul]:list-disc [&_ul]:pl-6 [&_li]:my-1.5 [&_a]:text-brand">
      <p>
        By accessing {site.domain}, you agree to these terms. The site is
        operated by {site.parent}. Nothing on this site constitutes a binding
        offer or professional advice; it's marketing.
      </p>

      <h2>Marks &amp; content</h2>
      <p>
        "Glitch Executor", "Glitch Trade", "Glitch Edge", "Glitch Grow", the
        cobra mascot, and related marks are property of {site.parent}. Copy and
        screenshots are copyrighted and cannot be reproduced commercially
        without written permission.
      </p>

      <h2>Sub-brand sites</h2>
      <p>
        Trade, Edge, and Grow each operate under their own subdomain and ship
        their own terms covering product-specific commitments (pilot refunds,
        API usage, data residency). Terms here cover only the portfolio site
        itself.
      </p>

      <h2>Warranties</h2>
      <p>
        The site is provided as-is. Historical performance of client engagements
        is not a guarantee of future results for your account.
      </p>

      <h2>Contact</h2>
      <p>
        Legal notices: <a href={`mailto:${site.contactEmail}`}>{site.contactEmail}</a>.
      </p>
    </div>
  </section>
</Base>
